# Environment Configuration
NODE_ENV=development
PORT=3000

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deppi
DB_USER=deppi
DB_PASSWORD=your_secure_password_here
DB_SSL=false
DATABASE_URL=postgresql://deppi:your_secure_password_here@localhost:5432/deppi

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=noreply@deppi.ifce.edu.br
EMAIL_FROM_NAME=DEPPI IFCE Maracanaú

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,gif

# CORS Configuration
CORS_ORIGIN=http://localhost:4200
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_here

# Monitoring
SENTRY_DSN=https://your_sentry_dsn_here
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Frontend Configuration
FRONTEND_URL=http://localhost:4200
API_URL=http://localhost:3000

# SSL Configuration (for production)
SSL_CERT_PATH=/etc/ssl/certs/deppi.crt
SSL_KEY_PATH=/etc/ssl/private/deppi.key

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=deppi-backups
BACKUP_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Monitoring Credentials
GRAFANA_PASSWORD=admin_grafana_password
PROMETHEUS_PASSWORD=admin_prometheus_password

# Development
DEBUG=app:*
LOG_LEVEL=info

# Testing
TEST_DATABASE_URL=postgresql://deppi:your_secure_password_here@localhost:5432/deppi_test
TEST_REDIS_URL=redis://localhost:6379/1

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_SOCIAL_LOGIN=false
ENABLE_MAINTENANCE_MODE=false

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# Documentation
API_DOCS_ENABLED=true
API_DOCS_PATH=/api-docs

# Performance
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6

# Security Headers
HELMET_ENABLED=true
CSP_ENABLED=true

# PostgreSQL Connection Details
PGHOST=localhost
PGPORT=5432
PGDATABASE=deppi
PGUSER=deppi
PGPASSWORD=your_secure_password_here
